# ── GameHub FastAPI Backend — Environment Variables Template ───────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ── External API Keys ──────────────────────────────────────────────────────────
# RAWG Video Games Database: https://rawg.io/apidocs
RAWG_API_KEY=your_rawg_api_key_here

# NewsAPI: https://newsapi.org/account
NEWS_API_KEY=your_newsapi_key_here

# NewsData.io: https://newsdata.io/api-key
NEWSDATA_API_KEY=your_newsdata_api_key_here

# CoinGecko: https://www.coingecko.com/en/api
COINGECKO_API_KEY=your_coingecko_api_key_here

# ── Payments (PayPal) ────────────────────────────────────────────────────────
# PayPal Developer Dashboard: https://developer.paypal.com/dashboard/
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_MODE=sandbox

# ── Firebase Admin SDK ─────────────────────────────────────────────────────────
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Place the downloaded JSON at: backend/firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_PROJECT_ID=gamehub-b2b01

# ── Server Configuration ───────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_VERSION=1.0.0

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:3000

# ── Cache ──────────────────────────────────────────────────────────────────────
# Default TTL in seconds for in-memory cache entries
CACHE_DEFAULT_TTL=300

# ── Rate Limiting ──────────────────────────────────────────────────────────────
# Max requests per minute per IP address
RATE_LIMIT_PER_MINUTE=60
